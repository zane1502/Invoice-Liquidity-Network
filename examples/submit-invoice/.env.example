# Stellar secret key for the freelancer account submitting the invoice
FREELANCER_SECRET_KEY=

# Payer's Stellar address
PAYER_ADDRESS=

# Invoice amount (in stroops; 1 XLM = 10,000,000 stroops)
INVOICE_AMOUNT=10000000

# Due date as a Unix timestamp (in seconds since epoch)
INVOICE_DUE_DATE=

# Discount rate (percentage; e.g., 5 = 5%)
INVOICE_DISCOUNT_RATE=5

# ILN contract ID (uses testnet default if not specified)
# CONTRACT_ID=

# RPC URL (uses testnet default if not specified)
# RPC_URL=

# Network passphrase (uses testnet default if not specified)
# NETWORK_PASSPHRASE=
