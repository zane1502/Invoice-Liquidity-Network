{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@iln/shared": ["../packages/shared/src/index.ts"],
      "@iln/shared/*": ["../packages/shared/src/*"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2020", "DOM"],
    "types": ["node"]
  },
  "include": ["src", "__tests__", "tsup.config.ts"]
}
