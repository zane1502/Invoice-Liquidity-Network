{
  "name": "@invoice-liquidity/cli",
  "version": "0.1.0",
  "description": "Command-line interface for the Invoice Liquidity Network on Stellar.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "iln": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "prepare": "husky install",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration.test.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^15.0.1",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "@commitlint/cli": "^17.6.0",
    "@commitlint/config-conventional": "^17.6.0",
    "husky": "^8.0.0"
  }
}
