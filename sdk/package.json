{
  "name": "@invoice-liquidity/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Invoice Liquidity Network Soroban contract.",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "husky install",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:integration:testnet": "vitest run tests/integration/testnet.test.ts",
    "test:e2e-local": "vitest run __tests__/e2e/*.test.ts",
    "test:coverage": "vitest run --coverage",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@iln/shared": "workspace:*",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^15.0.1"
  },
  "devDependencies": {
    "@iln/eslint-config": "workspace:*",
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@commitlint/cli": "^17.6.0",
    "@commitlint/config-conventional": "^17.6.0",
    "fast-check": "^4.8.0",
    "husky": "^8.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}